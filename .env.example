# GitHub Personal Access Token (free: https://github.com/settings/tokens)
GITHUB_TOKEN=ghp_your_token_here

# Google Gemini API Key (free: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Additional GitHub tokens for rate limit rotation
# GITHUB_TOKEN_2=ghp_second_token
# GITHUB_TOKEN_3=ghp_third_token

# Database (SQLite, no config needed - auto-created at backend/data/builder_discovery.db)
DATABASE_URL=sqlite+aiosqlite:///./data/builder_discovery.db

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1
